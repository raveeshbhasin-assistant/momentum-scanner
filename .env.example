# Momentum Scanner — Environment variables template
# ───────────────────────────────────────────────────────
# Copy this file to `.env` locally, or add these keys in Railway →
# Project → Variables. `.env` is gitignored; never commit secrets.

# ── Port (Railway sets this automatically) ────────────
# PORT=8080

# ── Email notifier (v3.4.3) ───────────────────────────
# Strong-signal emails are sent only when ALL of the following are true:
#   1. NOTIFY_ENABLED is truthy (default: true)
#   2. GMAIL_USER and GMAIL_APP_PASSWORD are set
#   3. the scan emits at least NOTIFY_MIN_SIGNALS strong signals (default: 1)
#
# To get an app password:
#   1. Enable 2FA on the Gmail account at myaccount.google.com/security
#   2. Visit myaccount.google.com/apppasswords
#   3. Create a new 16-character password named "Momentum Scanner"
#   4. Paste it below (no spaces)

GMAIL_USER=your.sending.address@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# Where to send notifications. Comma-separated, defaults to GMAIL_USER.
NOTIFY_EMAIL=raveeshsingh@gmail.com

# Feature flag. Set to "false" to silence emails without removing creds.
NOTIFY_ENABLED=true

# Minimum number of strong signals to trigger an email (default: 1).
NOTIFY_MIN_SIGNALS=1

# Base URL of the live dashboard (used in email "View dashboard" button).
DASHBOARD_URL=https://trader-v3-production.up.railway.app

# ── Third-party APIs (existing) ───────────────────────
# FMP_API_KEY=...
# FINNHUB_API_KEY=...
